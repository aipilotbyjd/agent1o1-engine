# ── Database ──────────────────────────────────────
POSTGRES_USER=linkflow
POSTGRES_PASSWORD=changeme
POSTGRES_DB=linkflow
POSTGRES_PORT=5433

# ── Redis ─────────────────────────────────────────
REDIS_PASSWORD=changeme
REDIS_PORT=6380

# ── Secrets ───────────────────────────────────────
LINKFLOW_SECRET=your-shared-secret-min-32-chars
JWT_SECRET=your-jwt-secret-min-32-chars

# ── Engine Config ─────────────────────────────────
ENGINE_PARTITION_COUNT=16
ENGINE_HTTP_PORT=8080
ENGINE_GRPC_PORT=9090
LOG_LEVEL=info

# ── Laravel Callback URL ─────────────────────────
# This is where the engine sends execution results back to your Laravel app.
# For Docker on macOS: http://host.docker.internal (Herd serves on port 80/443)
# For Docker on Linux: http://172.17.0.1 (Docker host gateway)
CALLBACK_URL=http://host.docker.internal/api/v1/jobs/callback
